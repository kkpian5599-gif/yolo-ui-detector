{
  "_meta": {
    "description": "Style recipe for synthetic data generator, extracted from 4 real websites",
    "sources": ["github.com/login", "element-plus.org", "getbootstrap.com/checkout", "getbootstrap.com/dashboard"],
    "date": "2026-04-30"
  },

  "inputs": {
    "border_normal": "1px solid #dee2e6",
    "border_focused": "1px solid #0969da (or #86b7fe with glow)",
    "border_error": "1px solid #f56c6c",
    "radius_options": ["4px", "6px", "8px"],
    "focus_glow": "0 0 0 0.25rem rgba(13,110,253,0.25)",
    "bg": "#ffffff",
    "text": "#212529",
    "placeholder": "#6c757d",
    "sizes": {
      "small": {"h": "24px", "pad": "5px 11px", "fs": "12px", "r": "3px"},
      "default": {"h": "38px", "pad": "6px 12px", "fs": "16px", "r": "6px"},
      "large": {"h": "40px", "pad": "8px 16px", "fs": "16px", "r": "6px"}
    },
    "disabled": {"bg": "#e9ecef", "text": "#6c757d", "border": "#dee2e6"}
  },

  "buttons": {
    "solid_colors": {
      "blue": "#0d6efd",
      "indigo": "#6610f2",
      "purple": "#712cf9",
      "green": "#67c23a",
      "dark_green": "#1f883d",
      "yellow": "#e6a23c",
      "red": "#f56c6c",
      "gray": "#6c757d"
    },
    "solid": {
      "note": "filled button, bg=color, text=white, border same as bg",
      "padding": {"default": "8px 15px", "small": "5px 11px", "large": "12px 19px"},
      "radius": {"default": "4px", "small": "3px", "large": "4px"},
      "font_size": {"default": "14px", "small": "12px", "large": "14px"},
      "height": {"default": "32px", "small": "24px", "large": "40px"}
    },
    "outline": {
      "note": "white bg, colored border and text",
      "bg": "#ffffff",
      "text": "#606266",
      "border": "1px solid #dcdfe6",
      "radius": "4px"
    },
    "plain": {
      "note": "light tinted bg, colored text, light border",
      "blue":  {"bg": "#ecf5ff", "text": "#409eff", "border": "#a0cfff"},
      "green": {"bg": "#f0f9eb", "text": "#67c23a", "border": "#b3e19d"},
      "red":   {"bg": "#fef0f0", "text": "#f56c6c", "border": "#fab6b6"}
    },
    "dashed": {
      "bg": "#ffffff",
      "border": "1px dashed #dcdfe6",
      "text": "#606266"
    },
    "round": {"border_radius": "20px", "base": "same as solid/outline"},
    "circle": {"border_radius": "50%", "size": "32px", "pad": "8px"},
    "text_only": {
      "bg": "transparent",
      "text": "theme color",
      "border": "none",
      "pad": "2px to 8px 15px"
    },
    "text_with_bg": {
      "bg": "#f5f7fa",
      "text": "theme color",
      "border": "none"
    },
    "disabled_patterns": {
      "solid": "bg becomes lighter tint, cursor not-allowed",
      "outline": "text #a8abb2, border #e4e7ed",
      "plain": "all colors lighter",
      "text": "color lighter tint"
    },
    "button_group": {
      "first": "border-radius right=0",
      "middle": "border-radius 0",
      "last": "border-radius left=0"
    },
    "icon_button": {"sizes": ["32x32", "24x24"], "pad": "8px"}
  },

  "checkboxes_and_radios": {
    "checkbox": {"size": "16x16", "radius": "4px", "border": "1px solid #dee2e6"},
    "radio": {"size": "16x16", "radius": "50%", "border": "1px solid #dee2e6", "checked_bg": "#0d6efd"},
    "select": {"same_as_input": true, "arrow_pad_right": "36px"}
  },

  "links": {
    "body_link": {"color": "#0d6efd", "fs": "16px"},
    "nav_link": {"color": "#0d6efd", "fs": "14px", "pad": "8px 16px", "no_underline": true},
    "footer_link": {"color": "#59636e", "fs": "12px"}
  },

  "dark_theme": {
    "bg_page": ["#0d1117", "#1a1a2e", "#212529"],
    "bg_card": ["#161b22", "#2d2d44"],
    "text_primary": ["#e6edf3", "#c9d1d9"],
    "text_secondary": ["#8b949e", "#6e7681"],
    "border": ["#30363d", "#3a3a5c"],
    "input_bg": ["#0d1117", "#212529"],
    "input_border": ["#30363d"],
    "btn_primary": ["#1f6feb", "#238636"]
  },

  "modals_and_overlays": {
    "backdrop": {
      "colors": ["rgba(0,0,0,0.45)", "rgba(0,0,0,0.5)", "rgba(0,0,0,0.65)"],
      "blur": "backdrop-filter: blur(4px) optional"
    },
    "modal_card": {
      "bg": "#ffffff",
      "radius": "8px",
      "shadow": "0 4px 24px rgba(0,0,0,0.15)",
      "pad": "24px",
      "w_min": "320px",
      "w_max": "520px"
    },
    "modal_dark": {"bg": "#161b22", "shadow": "0 4px 24px rgba(0,0,0,0.5)"},
    "modal_buttons": {"layout": "right-aligned", "texts": ["OK / Cancel", "Confirm / Cancel"]},
    "toast": {
      "position": ["top-right", "top-center"],
      "colors": {"success": "#67c23a", "error": "#f56c6c", "warning": "#e6a23c", "info": "#909399"},
      "radius": "6px",
      "pad": "12px 20px",
      "shadow": "0 2px 12px rgba(0,0,0,0.1)"
    },
    "tooltip": {
      "bg": "#303133",
      "text": "#ffffff",
      "radius": "4px",
      "pad": "6px 10px",
      "fs": "12px"
    },
    "cookie_banner": {
      "pos": "fixed bottom",
      "bg": "#ffffff",
      "border_top": "1px solid #dee2e6",
      "pad": "16px"
    },
    "loading_overlay": {
      "bg": "semi-transparent full-screen",
      "spinner": "centered 24-40px theme color"
    }
  },

  "layout_patterns": {
    "sidebar_nav": {"w": "200-250px", "link_pad": "8px 16px", "link_color": "#0d6efd"},
    "form_page": {"max_w": "600-800px centered", "label": "above input", "gap": "16-24px"},
    "table": {
      "header_bg": "#f8f9fa",
      "border": "1px solid #dee2e6",
      "cell_pad": "8px 12px",
      "dark": {"header_bg": "#212529", "border": "#373b3e"}
    }
  },

  "fonts": {
    "system": [
      "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto",
      "system-ui, -apple-system, 'Segoe UI'",
      "'Mona Sans VF', -apple-system"
    ],
    "mono": "'SFMono-Regular', Menlo, Monaco, Consolas, monospace",
    "sizes_common": ["12px", "14px", "16px", "20px", "24px"]
  }
}
